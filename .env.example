# Default mode is dry-run. Keep this as 0 unless you deliberately want live chain writes.
LIVE_TRADING=0

# Required only for live mode.
RPC_HTTP_URL=
RPC_WS_URL=
CHAIN_ID=4
CHAIN_NAME=rinkeby

# Backend/client defaults.
BACKEND_PORT=8081
BACKEND_URL=http://localhost:8081/arbitrage
ARBITRAGE_STRATEGY=2

# Required only for live mode. Use private keys without a 0x prefix.
PRIVATE_KEY_1=
PRIVATE_KEY_2=

# Required only for live mode. Use addresses for the same network as the RPC URLs.
BUY_IN_ACCOUNT=
BUY_OUT_ACCOUNT=
FACTORY_CONTRACT_ADDRESS=
ROUTER_CONTRACT_ADDRESS=
WETH9_CONTRACT_ADDRESS=
TEST_CONTRACT_ADDRESS=

# Trade sizing used by the live backend. Dry-run tests do not need balances.
# Sell requests require the buy-out account to approve the router for the test token before live use.
ARBITRAGE_TEST_TOKEN_AMOUNT=0.01
ARBITRAGE_ETH_AMOUNT=0.005
